# =============================================================================
# Loc Sentinel — environment configuration
# Copy to .env and fill in. .env is gitignored; NEVER commit real secrets.
# The repo is PUBLIC. If a token ever leaks into a log, rotate it immediately.
# =============================================================================

# --- Anthropic (translation engine) -----------------------------------------
# Only required to translate brand-new strings (TM hits + QA run with no key).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model id for the grounded translator. Defaults are sane; override if needed.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Crowdin (source of strings + write-back) --------------------------------
CROWDIN_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CROWDIN_PROJECT_ID=123456
# Only set CROWDIN_BASE_URL for Crowdin Enterprise (e.g. https://acme.api.crowdin.com)
# Leave blank for crowdin.com (defaults to https://api.crowdin.com).
CROWDIN_BASE_URL=
# Secret you set when creating the webhook in Crowdin (used to verify signatures).
CROWDIN_WEBHOOK_SECRET=choose-a-long-random-string

# --- Slack (Socket Mode — no public URL needed for Slack) --------------------
# See SLACK_SETUP.md for click-by-click instructions to obtain these.
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxxxx-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_LOC_CHANNEL_ID=C0XXXXXXXXX

# --- Webhook receiver (FastAPI) ----------------------------------------------
# Public URL of your tunnel (ngrok/cloudflared) where Crowdin posts webhooks.
PUBLIC_BASE_URL=https://your-tunnel.ngrok-free.app
WEBHOOK_PORT=8000

# --- Languages ---------------------------------------------------------------
# Crowdin locale ids for the target markets. Source is English.
TARGET_LANGS=de,pt-BR,es

# --- Playground / demo mode --------------------------------------------------
# When true, the web console works with NO Anthropic key by serving the
# committed translation cache for sample strings. BYO-key still works live.
DEMO_MODE=true
# Optional: throttle the hosted demo so our key isn't abused (requests/min/ip).
DEMO_RATE_LIMIT_PER_MIN=20
